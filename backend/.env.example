# Süz-Geç Backend — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin.

PORT=9000
NODE_ENV=development

# MongoDB Bağlantı URI'si
MONGO_URI=mongodb+srv://kullanici:sifre@cluster.mongodb.net/suzgecdb?retryWrites=true&w=majority

# JWT Gizli Anahtar
JWT_SECRET=suzgec_gizli_anahtar_degistir

# Redis Bağlantı URL'si (Docker: redis://redis:6379)
REDIS_URL=redis://localhost:6379

# RabbitMQ Bağlantı URL'si (Docker: amqp://rabbitmq:5672)
RABBITMQ_URL=amqp://localhost:5672

# DataForSEO API
DATAFORSEO_LOGIN=your_login
DATAFORSEO_PASSWORD=your_password

# Serper API
SERPER_API_KEY=your_api_key

# ScraperAPI
SCRAPERAPI_KEY=your_api_key

# Gemini API
GEMINI_API_KEY=your_api_key

# Cron Secret (stok kontrol tetikleyici)
CRON_SECRET=suzgeccron123
